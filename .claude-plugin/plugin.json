{
  "name": "yeoboya-workflow-v2",
  "version": "0.4.1",
  "description": "앱팀 공통 harness-engineering 워크플로우 플러그인 V2 (Android / iOS) — 계획→TDD→검증→bug-fix 닫힌 루프",
  "author": {
    "name": "yeoboya"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/block-dangerous-command.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/harness-decay-notify.sh" }
        ]
      }
    ]
  }
}
